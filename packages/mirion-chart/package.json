{
  "name": "@kvis/mirion-chart",
  "version": "0.1.0",
  "type": "module",
  "description": "Clean, modern chart components for Mirion decks. Wraps Semiotic v3.",
  "main": "./dist/mirion-chart.cjs",
  "module": "./dist/mirion-chart.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mirion-chart.js",
      "require": "./dist/mirion-chart.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/mirion-chart.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite build --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "semiotic": "^3.3.1"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^25.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "semiotic": "^3.3.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.8"
  }
}
