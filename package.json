{
  "name": "mirion",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/mirion.cjs",
  "module": "dist/mirion.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/mirion.js",
      "require": "./dist/mirion.cjs",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/mirion.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "tsc -b && vite build",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview --config vite.demo.config.ts"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "workspaces": [
    "demo"
  ]
}
